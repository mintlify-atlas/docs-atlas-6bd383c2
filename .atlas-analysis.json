  "keyFeatures": [
    "ALPACA API client for telescope, camera, focuser, and filter wheel control",
    "Web-based control dashboard (Flask, port 5173) with live SSE log stream",
    "Automated FITS file detection via inotify/FSEvents ImageWatcher",
    "8-step local differential photometry pipeline with AAVSO VSP and Gaia DR3 comparison star queries",
    "AAVSO Extended File Format submission with full audit trail",
    "Science-ready FITS export with enriched observatory and processing headers",
    "SafetyManager watchdog with automatic dawn parking and reconnection",
    "Cloud communicator for Boundless Skies network registration, heartbeats, plan polling, and measurement upload",
    "Live stacking with translation-only star alignment for alt-az mounts",
    "Night scheduler with Messier/NGC object catalog and schedule runner"
  ],
  "publicApiSurface": [
    "photometry.run_pipeline(fits_path, config) -> dict | None",
    "aavso_submission.submit(measurement, config) -> dict",
    "fits_export.export_enhanced_fits(source_fits, result, config, export_dir=None) -> str | None",
    "image_watcher.ImageWatcher(watch_path, callback, debounce_delay) — .start(), .stop()",
    "alpaca.safety_manager.SafetyManager — .attach_telescope(), .start(), .stop(), .is_safe(), .status()",
    "cloud_communicator.CloudCommunicator(config, get_conditions, on_plan, on_interrupt) — .start(), .stop(), .submit_measurement()",
    "stacking.LiveStacker — .add_frame(), .stacked_image(), .preview_png_b64(), .reset()",
    "shared_models.NodeInfo, TargetInfo, PlanItem, ObservationPlan, Measurement — .to_dict(), .from_dict()",
    "geolocation.detect_location() -> dict | None",
    "geolocation.enrich_config_with_location(config) -> dict",
    "GET /api/status",
    "GET /api/logs (SSE)",
    "POST /api/discover",
    "POST /api/connect",
    "POST /api/disconnect",
    "POST /api/telescope/slew",
    "POST /api/telescope/park",
    "POST /api/telescope/unpark",
    "POST /api/telescope/tracking",
    "POST /api/camera/expose",
    "GET  /api/fits/list",
